# Hostinger MySQL - required for lead storage
DB_HOST=your_hostinger_mysql_host
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
# Set to true only if your MySQL host requires SSL
DB_SSL=false

# Lead notifications - optional but recommended
# Email notification is sent only when set.
RESEND_API_KEY=your_resend_api_key
LEAD_NOTIFICATION_TO=shad.edims@gmail.com
LEAD_NOTIFICATION_FROM=Mauri <onboarding@resend.dev>

# PostHog - optional analytics; build succeeds without this
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Public app URLs
NEXT_PUBLIC_APP_URL=https://www.mauri.in
NEXT_PUBLIC_API_URL=https://www.mauri.in/api
